def run_init():
    cwd        = Path.cwd()
    config     = cwd / "paperhouse.toml"
    photos_dir = cwd / "photos" / "example-photo"
    meta_file  = photos_dir / "meta.md"
    css_file   = cwd / "site" / "assets" / "style.css"

    created = []
    skipped = []

    def scaffold(path: Path, content: str):
        if path.exists():
            skipped.append(path.name)
            return
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content)
        created.append(str(path.relative_to(cwd)))

    today = datetime.now().strftime("%Y-%m-%d")
    scaffold(config,    STARTER_TOML)
    scaffold(meta_file, STARTER_META.format(today=today))
    scaffold(css_file,  STARTER_CSS)

    print()
    print("Paperhouse — new project setup")
    print("─" * 42)
    for f in created:  print(f"  Created  {f}")
    for f in skipped:  print(f"  Skipped  {f}  (already exists)")

    if created:
        print()
        print("Next steps:")
        print("  1. Open paperhouse.toml and fill in your details")
        print("     (name, site URL, email, nav links)")
        print()
        print("  2. Add your photos to the photos/ folder.")
        print("     Each photo lives in its own folder:")
        print()
        print("       photos/brooklyn-bridge/")
        print("         brooklyn-bridge.jpg")
        print("         meta.yaml")
        print()
        print("     meta.md frontmatter fields:")
        print("       caption:  The photo caption (required)")
        print("       date:     YYYY-MM-DD (overrides file metadata)")
        print("       location: City, State (optional)")
        print("       alt:      Alt text for accessibility (falls back to caption)")
        print("       draft:    true to hide from builds")
        print()
        print("     In Obsidian, meta.md shows a native properties panel")
        print("     and you can embed the photo with ![[photo.jpg]]")
        print()
        print("  3. Preview your first build:")
        print("       paperhouse --dry")
        print()
        print("  4. Build your site:")
        print("       paperhouse")
        print()
        print("  Your starter stylesheet is at site/assets/style.css")
        print("  Customize the colors, fonts, and layout to make it your own.")
    else:
        print()
        print("Nothing new to create — project already exists.")

    print()
    print("Docs: https://github.com/scottsteinhardt/paperhouse")
    print()


if ARGS.command == "init":
