# ── Utilities ──────────────────────────────────────────────────────────────────
def slugify(s: str) -> str:
    s = s.lower()
    s = re.sub(r"[^\w\s-]", "", s)
    s = re.sub(r"[-\s]+", "-", s).strip("-")
    return s or "untitled"

def to_utc(d):
    if d is None: return None
    if isinstance(d, datetime):
        return d if d.tzinfo else d.replace(tzinfo=timezone.utc)
    if isinstance(d, date):
        return datetime(d.year, d.month, d.day, tzinfo=timezone.utc)
    if isinstance(d, str):
        try: return datetime.fromisoformat(d.replace("Z", "+00:00"))
        except ValueError: pass
        for fmt in ("%Y-%m-%d", "%B %d, %Y", "%B %-d, %Y"):
            try: return datetime.strptime(d, fmt).replace(tzinfo=timezone.utc)
            except ValueError: continue
    return None

def iso_date(dt):   return dt.astimezone(timezone.utc).strftime("%Y-%m-%d") if dt else None
def iso_full(dt):   return dt.astimezone(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S+00:00") if dt else None
def pretty_date(dt): return dt.strftime("%B %-d, %Y") if dt else ""
def rfc822(dt):     return format_datetime(dt.astimezone(timezone.utc)) if dt else ""


# ── Image discovery ────────────────────────────────────────────────────────────
IMAGE_EXTS = (".jpg", ".jpeg", ".png", ".webp", ".avif", ".gif")

def find_photo_image(folder: Path) -> Path | None:
    for ext in IMAGE_EXTS:
        for p in sorted(folder.iterdir()):
            if p.is_file() and p.suffix.lower() == ext:
                return p
    return None


# ── Schema.org Person block ────────────────────────────────────────────────────
def person_schema() -> str:
    person = {"@context": "https://schema.org", "@type": "Person", "name": AUTHOR, "url": BASE}
    if EMAIL:   person["email"]  = EMAIL
    if SAME_AS: person["sameAs"] = SAME_AS
    if LOC_CITY or LOC_REGION:
        addr = {"@type": "PostalAddress", "addressCountry": LOC_COUNTRY}
        if LOC_CITY:   addr["addressLocality"] = LOC_CITY
        if LOC_REGION: addr["addressRegion"]   = LOC_REGION
        person["address"] = addr
    return json.dumps(person, indent=2)

PERSON_SCHEMA = person_schema()


