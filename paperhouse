# ── Nav ────────────────────────────────────────────────────────────────────────
def build_nav() -> str:
    if not _nav:
        return "<nav></nav>"
    lines = ["<nav>"]
    for link in _nav:
        href      = link.get("href",      "#")
        label     = link.get("label",     "")
        external  = ' target="_blank" rel="noopener"' if link.get("external") else ""
        lines.append(f'        <a href="{href}"{external}>{html.escape(label)}</a>')
    lines.append("      </nav>")
    return "\n".join(lines)

