    esc_can   = canonical

    article_meta = ""
    if og_type == "article" and pub_iso:
        article_meta = (
            f'\n  <meta property="article:published_time" content="{pub_iso}">'
            f'\n  <meta property="article:modified_time" content="{upd_iso or pub_iso}">'
            f'\n  <meta property="article:author" content="{html.escape(AUTHOR)}">'
        )

    return f"""\
  <meta charset="UTF-8">
  {THEME_INIT_SCRIPT}
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{esc_title}</title>

  <meta name="description" content="{esc_desc}">
  <meta name="author" content="{html.escape(AUTHOR)}">
  <meta name="copyright" content="{html.escape(AUTHOR)}">
  <meta name="robots" content="index, follow">

  <link rel="canonical" href="{esc_can}">

  <meta property="og:type" content="{og_type}">
  <meta property="og:title" content="{esc_title}">
  <meta property="og:description" content="{esc_desc}">
  <meta property="og:url" content="{esc_can}">
  <meta property="og:site_name" content="{html.escape(TITLE)}">
  <meta property="og:image" content="{esc_og}">
  <meta property="og:locale" content="{LOCALE}">{article_meta}

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{esc_title}">
  <meta name="twitter:description" content="{esc_desc}">
  <meta name="twitter:image" content="{esc_og}">

  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="shortcut icon" href="/favicon.ico">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="{CSS_URL}">
  <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="{BASE}/feed.xml">"""


# ── Load photos ────────────────────────────────────────────────────────────────
def load_photos() -> list[dict]:
    photos = []
    if not PHOTOS_DIR.exists():
        return photos

    for folder in sorted(PHOTOS_DIR.iterdir()):
        if not folder.is_dir() or folder.name.startswith(".") or folder.name.startswith("_"):
            continue

        # meta.md (YAML frontmatter, Obsidian-native) takes priority over meta.yaml
        meta_file = folder / "meta.md"
        if not meta_file.exists():
            meta_file = folder / "meta.yaml"
        if not meta_file.exists():
            print(f"  ! skipping {folder.name}: no meta.md or meta.yaml", file=sys.stderr)
            continue

        try:
            raw = meta_file.read_text()
            if meta_file.suffix == ".md":
                fm = re.match(r'^---\s*\n(.*?\n)---\s*\n?', raw, re.DOTALL)
                meta = yaml.safe_load(fm.group(1)) or {} if fm else {}
            else:
                meta = yaml.safe_load(raw) or {}
        except yaml.YAMLError as e:
            print(f"  ! YAML error in {folder.name}: {e}", file=sys.stderr)
            continue

        if meta.get("draft"):
            print(f"  - skip draft: {folder.name}")
            continue

        image_path = find_photo_image(folder)
        if not image_path:
            print(f"  ! skipping {folder.name}: no image file found", file=sys.stderr)
            continue

        caption  = str(meta.get("caption") or "").strip()
        dt       = to_utc(meta.get("date")) or datetime.fromtimestamp(
            meta_file.stat().st_mtime, tz=timezone.utc
        )
        location = str(meta.get("location") or "").strip()
        alt      = str(meta.get("alt")      or caption).strip()
        slug     = slugify(str(meta.get("slug") or folder.name))

        photos.append({
            "slug":     slug,
            "caption":  caption,
            "date":     dt,
            "location": location,
            "alt":      alt,
            "_folder":  folder,
            "_image":   image_path,
        })

    return sorted(
        photos,
        key=lambda p: p["date"] or datetime.min.replace(tzinfo=timezone.utc),
        reverse=True,
    )


# ── Render: index ──────────────────────────────────────────────────────────────
def render_index(photos: list[dict]) -> str:
    cards = []
    for p in photos:
        img_url = html.escape(p.get("image_url", ""))
        slug    = p["slug"]
        caption = html.escape(p["caption"])
        alt     = html.escape(p["alt"])
        meta_parts = []
        if p["date"]:     meta_parts.append(html.escape(pretty_date(p["date"])))
        if p["location"]: meta_parts.append(html.escape(p["location"]))
        meta_html = "".join(f"<span>{m}</span>" for m in meta_parts)

        cards.append(
            f'      <a href="{BASE}/{slug}/" class="photo-card">\n'
            f'        <div class="photo-thumb">'
            f'<img src="{img_url}" alt="{alt}" loading="lazy"></div>\n'
            f'        <p class="card-caption">{caption}</p>\n'
            f'        <div class="card-meta">{meta_html}</div>\n'
            f'      </a>'
        )

    grid_html = "\n\n".join(cards)
    schema = {
        "@context": "https://schema.org",
        "@type":    "ImageGallery",
        "name":     TITLE,
        "description": INDEX_DESC,
        "url":      f"{BASE}/",
        "author":   {"@type": "Person", "name": AUTHOR, "url": BASE},
    }

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
{page_head(
    title=TITLE,
    desc=INDEX_DESC,
    canonical=f"{BASE}/",
    og_image=DEFAULT_OG,
)}

  <script type="application/ld+json">
  {PERSON_SCHEMA}
  </script>
  <script type="application/ld+json">
  {json.dumps(schema, indent=2)}
  </script>
</head>
<body>
  <div class="container">
{site_header_html()}

    <main>
      <div class="photo-grid">
{grid_html}
      </div>
    </main>

{site_footer_html()}
  </div>

{THEME_TOGGLE_SCRIPT}
</body>
</html>
"""


# ── Render: single photo page ──────────────────────────────────────────────────
def render_photo_page(p: dict, prev_p: dict | None, next_p: dict | None) -> str:
    slug      = p["slug"]
    caption   = p["caption"]
    alt       = p["alt"]
    location  = p["location"]
    dt        = p["date"]
    img_url   = p.get("image_url", "")
    canonical = f"{BASE}/{slug}/"
    pub_iso   = iso_full(dt) or ""
    pretty    = pretty_date(dt)

    meta_parts = []
    if pretty:   meta_parts.append(f'<span>{html.escape(pretty)}</span>')
    if location: meta_parts.append(f'<span>{html.escape(location)}</span>')
    meta_html = "\n          ".join(meta_parts)

    pager_html = ""
    if prev_p or next_p:
        prev_html = ""
        next_html = ""
        if prev_p:
            prev_html = (
                f'<a href="{BASE}/{prev_p["slug"]}/" class="pager-prev">'
                f'{html.escape(prev_p["caption"][:60])}'
                f'{"…" if len(prev_p["caption"]) > 60 else ""}</a>'
            )
        if next_p:
            next_html = (
                f'<a href="{BASE}/{next_p["slug"]}/" class="pager-next">'
                f'{html.escape(next_p["caption"][:60])}'
                f'{"…" if len(next_p["caption"]) > 60 else ""}</a>'
            )
        pager_html = (
            f'\n        <nav class="photo-pager">\n'
            f'          {prev_html}\n'
            f'          {next_html}\n'
            f'        </nav>'
        )

    photograph_schema = {
        "@context":       "https://schema.org",
        "@type":          "Photograph",
        "name":           caption,
        "contentUrl":     img_url,
        "url":            canonical,
        "datePublished":  pub_iso,
        "author":         {"@type": "Person", "name": AUTHOR, "url": BASE},
        "copyrightHolder":{"@type": "Person", "name": AUTHOR},
    }
    if location:
        photograph_schema["contentLocation"] = {"@type": "Place", "name": location}

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
{page_head(
    title=f"{caption} | {TITLE}",
    desc=f"{caption}{(' — ' + location) if location else ''}",
    canonical=canonical,
    og_image=img_url,
    og_type="article",
    pub_iso=pub_iso,
)}

  <script type="application/ld+json">
  {PERSON_SCHEMA}
  </script>
  <script type="application/ld+json">
  {json.dumps(photograph_schema, indent=2)}
  </script>
</head>
<body>
  <div class="container">
{site_header_html()}

    <main>
      <div class="photo-single">
        <div class="photo-img-wrap">
          <img src="{html.escape(img_url)}" alt="{html.escape(alt)}">
        </div>
        <p class="photo-full-caption">{html.escape(caption)}</p>
        <div class="photo-full-meta">
          {meta_html}
        </div>{pager_html}
      </div>
    </main>

{site_footer_html()}
  </div>

{THEME_TOGGLE_SCRIPT}
</body>
</html>
"""


# ── Render: RSS feed ───────────────────────────────────────────────────────────
def render_feed(photos: list[dict]) -> str:
    last = max((p["date"] for p in photos if p["date"]), default=datetime.now(timezone.utc))
    lines = [
        '<?xml version="1.0" encoding="utf-8"?>',
        '<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">',
        '  <channel>',
        f'    <title>{html.escape(TITLE)}</title>',
        f'    <link>{BASE}/</link>',
        f'    <atom:link href="{BASE}/feed.xml" rel="self" type="application/rss+xml" />',
        f'    <description>{html.escape(INDEX_DESC)}</description>',
        '    <language>en-us</language>',
        f'    <copyright>All rights reserved, {html.escape(AUTHOR)}</copyright>',
        f'    <lastBuildDate>{rfc822(last)}</lastBuildDate>',
        '    <generator>Paperhouse</generator>',
    ]
    for p in photos:
        url     = f"{BASE}/{p['slug']}/"
        img_url = p.get("image_url", "")
        desc    = p["caption"]
        if p["location"]: desc += f" — {p['location']}"
        lines.append('    <item>')
        lines.append(f'      <title><![CDATA[{p["caption"]}]]></title>')
        lines.append(f'      <link>{url}</link>')
        lines.append(f'      <guid isPermaLink="true">{url}</guid>')
        if p["date"]: lines.append(f'      <pubDate>{rfc822(p["date"])}</pubDate>')
        lines.append(f'      <description><![CDATA[{desc}]]></description>')
        if img_url:
            low  = img_url.lower().split("?")[0]
            mime = "image/jpeg"
            for ext, m in {".png": "image/png", ".webp": "image/webp",
                           ".avif": "image/avif", ".gif": "image/gif"}.items():
                if low.endswith(ext): mime = m; break
            lines.append(f'      <enclosure url="{html.escape(img_url)}" type="{mime}" length="0" />')
        lines.append('    </item>')
    lines += ['  </channel>', '</rss>']
    return "\n".join(lines) + "\n"


# ── Render: sitemap ────────────────────────────────────────────────────────────
def render_sitemap(photos: list[dict]) -> str:
    last = max((p["date"] for p in photos if p["date"]), default=datetime.now(timezone.utc))
    parts = [
        '<?xml version="1.0" encoding="UTF-8"?>',
        '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">',
        f'  <url>\n    <loc>{BASE}/</loc>\n    <lastmod>{iso_date(last)}</lastmod>\n    <changefreq>weekly</changefreq>\n    <priority>1.0</priority>\n  </url>',
    ]
    for p in photos:
        upd = iso_date(p["date"]) or ""
        parts.append(
            f'  <url>\n    <loc>{BASE}/{p["slug"]}/</loc>\n'
            f'    <lastmod>{upd}</lastmod>\n'
            f'    <changefreq>yearly</changefreq>\n    <priority>0.7</priority>\n  </url>'
        )
    parts.append('</urlset>')
    return "\n".join(parts) + "\n"


# ── Render: llms.txt ───────────────────────────────────────────────────────────
def render_llms(photos: list[dict]) -> str:
    lines = [
        f"# {TITLE}", "",
        f"> {INDEX_DESC}", "",
        "## Photos", "",
        "Listed newest first.", "",
    ]
    for p in photos:
        url  = f"{BASE}/{p['slug']}/"
        meta = []
        if p["date"]:     meta.append(iso_date(p["date"]) or "")
        if p["location"]: meta.append(p["location"])
        line = f"- [{p['caption']}]({url})"
        if meta: line += " — " + ", ".join(meta)
        lines.append(line)
    lines += [
        "", "## Feeds", "",
        f"- [RSS]({BASE}/feed.xml)",
        f"- [Sitemap]({BASE}/sitemap.xml)", "",
    ]
    if EMAIL: lines += ["## Contact", "", f"- Email: {EMAIL}", ""]
    return "\n".join(lines)


# ── Main ───────────────────────────────────────────────────────────────────────
def write_file(path: Path, content: str):
    if DRY:
        print(f"  [dry] would write {path.relative_to(SITE_DIR)} ({len(content):,} bytes)")
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")

def copy_file(src: Path, dest: Path):
    if DRY:
        print(f"  [dry] would copy  {src.name} -> {dest.relative_to(SITE_DIR)}")
        return
    dest.parent.mkdir(parents=True, exist_ok=True)
    if not dest.exists() or src.stat().st_mtime > dest.stat().st_mtime:
        shutil.copy2(src, dest)

def main():
    if not PHOTOS_DIR.exists():
        PHOTOS_DIR.mkdir(parents=True)
        print(f"created {PHOTOS_DIR} (empty)")

    print("Loading photos...")
    photos = load_photos()
    print(f"  {len(photos)} photos")

    if not photos:
        print("Nothing to build — add photos to your photos/ directory.")
        sys.exit(0)

    image_copies = []

    for p in photos:
        slug  = p["slug"]
        dt    = p["date"]
        src   = p["_image"]
        ym    = dt.strftime("%Y/%m") if dt else "unknown"
        dest  = SITE_DIR / "images" / ym / slug / src.name
        image_copies.append((src, dest))
        p["image_url"] = f"{BASE}/images/{ym}/{slug}/{src.name}"

    for src, dest in image_copies:
        copy_file(src, dest)

    print("Rendering photo pages...")
    for i, p in enumerate(photos):
        prev_p = photos[i - 1] if i > 0            else None
        next_p = photos[i + 1] if i < len(photos) - 1 else None
        page   = render_photo_page(p, prev_p, next_p)
        write_file(SITE_DIR / p["slug"] / "index.html", page)
        print(f"  + {p['slug']}  -> /{p['slug']}/")

    print("Rebuilding index...")
    write_file(SITE_DIR / "index.html", render_index(photos))
    print("Rebuilding feed.xml...")
    write_file(SITE_DIR / "feed.xml", render_feed(photos))
    print("Rebuilding sitemap.xml...")
    write_file(SITE_DIR / "sitemap.xml", render_sitemap(photos))
    print("Rebuilding llms.txt...")
    write_file(SITE_DIR / "llms.txt", render_llms(photos))

    print()
    print(f"Done. {len(photos)} photos rendered; {len(image_copies)} images copied.")

    if not DRY:
        now      = datetime.now()
        zip_name = now.strftime("UPLOAD THIS AS OF %Y-%m-%d %-I:%M %p.zip")
        zip_path = SITE_DIR.parent / zip_name
        print(f"Zipping site -> {zip_path.name}")
        with zipfile.ZipFile(zip_path, "w", zipfile.ZIP_DEFLATED) as zf:
            for f in SITE_DIR.rglob("*"):
                if f.is_file():
                    zf.write(f, f.relative_to(SITE_DIR.parent))
        print(f"  {zip_path.stat().st_size // 1024:,} KB  ->  {zip_path}")


if __name__ == "__main__":
    main()
