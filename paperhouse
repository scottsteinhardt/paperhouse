# ── Config ─────────────────────────────────────────────────────────────────────
def load_config(path: str) -> dict:
    candidates = [Path(path), Path.home() / ".paperhouse.toml"]
    for p in candidates:
        if p.exists():
            with open(p, "rb") as f:
                return tomllib.load(f)
    sys.exit(
        "Config not found. Tried:\n"
        + "\n".join(f"  {p}" for p in candidates)
        + "\n\nRun 'paperhouse init' to set up a new project,"
        "\nor create a paperhouse.toml manually."
    )

